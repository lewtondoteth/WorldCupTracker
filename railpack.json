{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "install": {
      "commands": [
        "npm install",
        "npm --prefix server install",
        "npm --prefix client install"
      ]
    },
    "build": {
      "inputs": [
        {
          "step": "install"
        }
      ],
      "commands": [
        "npm --prefix client run build"
      ]
    }
  },
  "deploy": {
    "startCommand": "npm start"
  }
}
